{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "baseUrl": ".",
    "sourceMap": true,
    "declaration": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "importHelpers": true,
    "target": "esnext",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@tinywideclouds.com/libs-sim-generator": [
        "libs/sim/generator/src/index.ts"
      ],
      "@tinywideclouds.com/libs/sim/util-parsers": [
        "libs/sim/util-parsers/src/index.ts"
      ],
      "@tinywideclouds.com/libs/sim/data-access": [
        "libs/sim/data-access/src/index.ts"
      ],
      "@tinywideclouds.com/libs/sim/shared-ui": [
        "libs/sim/shared-ui/src/index.ts"
      ],
      "@tinywideclouds.com/libs/sim/features/actor-timeline": [
        "libs/sim/features/actor-timeline/src/index.ts"
      ],
      "@tinywideclouds.com/libs/sim/features/energy": [
        "libs/sim/features/energy/src/index.ts"
      ],
      "@tinywideclouds.com/libs/sim/features/log-explorer": [
        "libs/sim/features/log-explorer/src/index.ts"
      ],
      "@tinywideclouds.com/libs/sim/features/dashboard": [
        "libs/sim/features/dashboard/src/index.ts"
      ]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
