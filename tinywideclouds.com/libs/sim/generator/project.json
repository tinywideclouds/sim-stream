{
  "name": "libs-sim-generator",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/sim/generator/src",
  "projectType": "library",
  "tags": ["scope:generator"],
  "targets": {
    "generate": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["rimraf dist", "buf generate --template buf.gen.ts.yaml"],
        "cwd": "libs/llm/protos"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "buf lint",
        "cwd": "libs/llm/protos"
      }
    }
  }
}
