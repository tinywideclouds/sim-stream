{
  "name": "shared-ui",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/sim/shared-ui/src",
  "prefix": "sim",
  "projectType": "library",
  "tags": ["scope:sim"],
  "targets": {
    "build": {
      "executor": "@nx/angular:ng-packagr-lite",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "configurations": {
        "production": {
          "tsConfig": "libs/sim/shared-ui/tsconfig.lib.prod.json"
        },
        "development": {}
      },
      "defaultConfiguration": "production"
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "configFile": "libs/sim/shared-ui/vitest.config.mts",
        "reportsDirectory": "coverage/libs/sim/shared-ui"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
